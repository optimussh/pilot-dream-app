app = ""                    # fly launch가 자동으로 채워줍니다. 비워두세요.
primary_region = "nrt"      # Tokyo (한국에서 가장 가까운 지역)

[build]
  dockerfile = "Dockerfile"

[env]
  FLASK_ENV = "production"

[http_service]
  internal_port = 5000
  force_https = true
  auto_stop_machines = true
  auto_start_machines = true
  min_machines_running = 0

[[vm]]
  cpu_kind = "shared"
  cpus = 1
  memory_mb = 512